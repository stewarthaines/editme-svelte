{
  "id": "abc2svg+jsyaml",
  "name": "abc2svg+jsyaml",
  "description": "Render ABC music notation code blocks as SVG scores with abc2svg, engraved with the Bravura font; js-yaml reads each block's frontmatter options. Pre-rendered scale variants switch to fit the reading column.",
  "category": "code-blocks",
  "url": "https://chiselapp.com/user/moinejf/repository/abc2svg/doc/trunk/README.md",
  "license": "LICENSE.txt",
  "assets": [
    {
      "file": "themes/Bravura.woff2",
      "target": "Fonts/Bravura.woff2",
      "media": "application/font-woff"
    },
    {
      "file": "themes/font.css",
      "target": "Styles/abc-font.css",
      "media": "text/css"
    },
    {
      "file": "abc2svg.css",
      "target": "Styles/abc2svg.css",
      "media": "text/css"
    }
  ],
  "scripts": [
    "abc2svg-1.js",
    "js-yaml.min.js"
  ],
  "generators": [
    {
      "id": "abc-sample",
      "name": "ABC Sample",
      "description": "Insert a sample ABC tune: choose voices, key, tempo, lyrics and responsive scale variants.",
      "script": "abc-sample.js",
      "options": [
        {
          "type": "select",
          "name": "format",
          "label": "Plain text wrapper",
          "default": "markdown",
          "options": [
            {
              "value": "markdown",
              "label": "Markdown"
            },
            {
              "value": "textile",
              "label": "Textile"
            }
          ]
        },
        {
          "type": "select",
          "name": "voices",
          "label": "Voices",
          "default": "1",
          "options": [
            {
              "value": "1",
              "label": "1 voice"
            },
            {
              "value": "2",
              "label": "2 voices"
            },
            {
              "value": "3",
              "label": "3 voices"
            },
            {
              "value": "satb",
              "label": "SATB"
            }
          ]
        },
        {
          "type": "boolean",
          "name": "responsive",
          "label": "Responsive scale variants",
          "default": true
        },
        {
          "type": "select",
          "name": "tempo",
          "label": "Tempo",
          "default": "120",
          "options": [
            {
              "value": "60",
              "label": "Largo (60)"
            },
            {
              "value": "90",
              "label": "Andante (90)"
            },
            {
              "value": "120",
              "label": "Moderato (120)"
            },
            {
              "value": "144",
              "label": "Allegro (144)"
            }
          ]
        },
        {
          "type": "select",
          "name": "key",
          "label": "Key",
          "default": "C",
          "options": [
            {
              "value": "C",
              "label": "C major"
            },
            {
              "value": "G",
              "label": "G major"
            },
            {
              "value": "D",
              "label": "D major"
            },
            {
              "value": "F",
              "label": "F major"
            },
            {
              "value": "Bb",
              "label": "B♭ major"
            },
            {
              "value": "Am",
              "label": "A minor"
            },
            {
              "value": "Em",
              "label": "E minor"
            },
            {
              "value": "Dm",
              "label": "D minor"
            }
          ]
        },
        {
          "type": "boolean",
          "name": "words",
          "label": "Include sample lyrics",
          "default": false
        }
      ]
    }
  ],
  "domTransforms": [
    "transformABC.js"
  ],
  "textTransforms": []
}
