# Google Drive OAuth Configuration
#
# To enable Google Drive support:
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable "Google Drive API" and "Google Picker API"
# 3. Create OAuth 2.0 credentials (Web Application)
#    - Add your origin to "Authorized JavaScript Origins" (e.g., http://localhost:8000)
# 4. Create an API Key (restrict to Google Picker API)
# 5. Copy the values below:

VITE_GOOGLE_CLIENT_ID=your-client-id-here
VITE_GOOGLE_API_KEY=your-api-key-here

# Dropbox OAuth Configuration
#
# To enable Dropbox support:
# 1. Create an app at https://www.dropbox.com/developers/apps
# 2. Choose "Scoped access" and "Full Dropbox"
# 3. Set permissions: files.content.write, files.metadata.read
# 4. Add redirect URIs in the app console (e.g., http://localhost:8000)
# 5. Copy the App Key below, and set the redirect URI to match exactly:

VITE_DROPBOX_APP_KEY=your-app-key-here
VITE_DROPBOX_REDIRECT_URI=http://localhost:8000
